# Input sides of triangle
a = float(input("Enter side a: "))
b = float(input("Enter side b: "))
c = float(input("Enter side c: "))

# Perimeter
perimeter = a + b + c

# Semi-perimeter
s = perimeter / 2

# Area using Heron's Formula
area = (s * (s - a) * (s - b) * (s - c)) ** 0.5

print("Perimeter =", perimeter)
print("Area =", area)